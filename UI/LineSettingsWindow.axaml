<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Photoshop.UI.LineSettingsWindow"
        Title="Линия"
        Width="300" Height="200"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20" Spacing="15">
       
        <TextBlock Text="Введите толщину линии:"/>
        
        <TextBox x:Name="ThicknessInput" 
                 TextChanged="OnTextChanged"/>
        
        <TextBlock x:Name="ErrorText" 
                   Foreground="Red" 
                   FontSize="12" 
                   IsVisible="False"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button x:Name="BtnOk" Content="OK" Click="OnOkClick" IsEnabled="False"/>
            <Button Content="Отмена" Click="OnCancelClick"/>
        </StackPanel>
    </StackPanel>
</Window>