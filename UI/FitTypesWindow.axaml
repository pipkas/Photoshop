<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Photoshop.UI.FitTypesWindow"
        xmlns:local="using:Photoshop.UI"
        Title="Interpolation type"
        SizeToContent="WidthAndHeight"
        MinWidth="400"  
        MaxWidth="600"                         
        MaxHeight="400"                       
        CanResize="True"
        WindowStartupLocation="CenterOwner">

    <ScrollViewer HorizontalScrollBarVisibility="Auto" 
            VerticalScrollBarVisibility="Auto">
                    
            <StackPanel Margin="20" Spacing="15" Orientation="Vertical">
                    
                <TextBlock Text="Выберите тип интерполяции:" 
                       FontWeight="Bold"
                       FontSize="16"/>

                <StackPanel Orientation="Vertical" Spacing="10">
                    <RadioButton x:Name="RadioCubic"
                        GroupName="InterpolationGroup"
                        Content="Кубическая интерполяция"
                        Tag="Cubic"
                        Checked="OnFitClick"/>
                
                    <RadioButton x:Name="RadioBilinear"
                        GroupName="InterpolationGroup"
                        Content="Билинейная интерполяция"
                        Tag="Bilinear"
                        Checked="OnFitClick"/>
                    
                    <RadioButton x:Name="RadioStep"
                        GroupName="InterpolationGroup"
                        Content="Ступенчатая интерполяция"
                        Tag="Step"
                        Checked="OnFitClick"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Bottom"
                    Spacing="20"
                    Margin="0,0,10,10">
                    <Button Content="Отмена" Click="OnCancelClick"/>
                    <Button x:Name="BtnOk" Content="OK" Click="OnOkClick" IsEnabled="False"/>
                </StackPanel>

            </StackPanel>

        </ScrollViewer> 

</Window>