<Window x:Name="MainWindowRoot"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:internal="using:Avalonia.Dialogs.Internal"
    xmlns:avalonia="https://github.com/avaloniaui"
    x:Class="Photoshop.UI.MainWindow"
    xmlns:vm="clr-namespace:Photoshop"
    Width="640"
    Height="480"
    Title="Photoshop">
    <Window.Styles>
        <Style Selector="Button.main-control, ComboBox.main-control">
                <Setter Property="Height" Value="30"/>
                <Setter Property="MinHeight" Value="30"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="0"/>
                <Setter Property="VerticalAlignment" Value="Top"/>
                <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Styles>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
            Orientation="Horizontal"
            Background = "rgb(253, 192, 113)">

            <Button Click="OnFileClick"
                    ToolTip.Tip="Открыть файл"
                    Classes="main-control">
                    File
            </Button>

            <Button Click="OnHelpClick"
                    ToolTip.Tip="О программе"
                    Classes="main-control">
                    Help
            </Button>

            <Button Click="OnSaveClick"
                    ToolTip.Tip="Сохранить в PNG"
                    Classes="main-control">
                    Save
            </Button>

            <ComboBox x:Name="FiltersComboBox" 
                HorizontalAlignment="Stretch"
                SelectedIndex="0"
                ToolTip.Tip="Фильтры"
                Classes="main-control">

                <ComboBoxItem IsEnabled="False">
                        <TextBlock Text="Filters"/>
                </ComboBoxItem>

            </ComboBox>

            <ComboBox x:Name="FitComboBox" 
                HorizontalAlignment="Stretch"
                SelectedIndex="0"
                ToolTip.Tip="Подогнать под экран"
                Classes="main-control">

                <ComboBoxItem IsEnabled="False">
                        <TextBlock Text="Fit"/>
                </ComboBoxItem>

                <ComboBoxItem Padding ="0">
                        <Button Click="OnFitClick"
                                Tag="Cubic"
                                ToolTip.Tip="Кубическая интерполяция"
                                HorizontalAlignment = "Stretch"
                                Background = "Transparent">
                                Cubic
                        </Button>
                </ComboBoxItem>

                <ComboBoxItem Padding ="0">
                        <Button Click="OnFitClick"
                                Tag="Bilinear"
                                ToolTip.Tip="Билинейная интерполяция"
                                HorizontalAlignment = "Stretch"
                                Background = "Transparent">
                                Bilinear
                        </Button>
                </ComboBoxItem>

                <ComboBoxItem Padding ="0">
                        <Button Click="OnFitClick"
                                Tag="Step"
                                ToolTip.Tip="Ступенчатая интерполяция"
                                HorizontalAlignment = "Stretch"
                                Background = "Transparent">
                                Step
                        </Button>
                </ComboBoxItem>

            </ComboBox>

            <Button x:Name="PixeltoPixelToggle" 
                Click="OnPixelToPixelClick"
                ToolTip.Tip="Реальный размер"
                Classes="main-control">
                Real size
             </Button> 
        </StackPanel>

        <StackPanel x:Name="LabelPanel"
             Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
             Orientation="Horizontal">

        </StackPanel>

        <Rectangle Grid.Row="2" Grid.Column="1" 
                x:Name="ViewportFrame"
                Stroke="Gray"
                StrokeThickness="1"
                IsHitTestVisible="False"
                Margin="7"/>

        <Border Grid.Row="2" Grid.Column="1"
                x:Name="ImageContainer"
                Background="{DynamicResource WindowBackground}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Grid>
                        <ScrollViewer x:Name="ImageScrollViewer"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto">

                        <Image x:Name="CanvasImage"
                                Stretch="None"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                PointerPressed="OnImagePointerPressed"/>
                        </ScrollViewer>
                </Grid>
        </Border>
    </Grid>
</Window>

