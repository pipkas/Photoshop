<Window x:Name="MainWindowRoot"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:internal="using:Avalonia.Dialogs.Internal"
    x:Class="Photoshop.UI.MainWindow"
    xmlns:vm="clr-namespace:Photoshop"
    Width="640"
    Height="480">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
            Orientation="Horizontal">

            <Button Click="OnFileClick"
                    ToolTip.Tip="Открыть файл">
                    File
            </Button>

            <Button Click="OnHelpClick"
                    ToolTip.Tip="О программе">
                    Help
            </Button>

            <Button Click="OnSaveClick"
                    ToolTip.Tip="Сохранить в PNG">
                    Save
            </Button>

            <ComboBox x:Name="FiltersComboBox" 
                HorizontalAlignment="Stretch"
                Margin="1,2,1,0"
                SelectedIndex="0"
                ToolTip.Tip="Фильтры">

                <ComboBoxItem IsEnabled="False">
                        <TextBlock Text="Filters"/>
                </ComboBoxItem>

            </ComboBox>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Grid.Column="1"
                      HorizontalScrollBarVisibility="Auto" 
                      VerticalScrollBarVisibility="Auto">
            <Image x:Name="CanvasImage"
                Stretch="None"
                PointerPressed="OnImagePointerPressed"/>
        </ScrollViewer>
    </Grid>
</Window>

