*.snupkg
*.symbols.nupkg

# NuGet Packages
packages/
*.nuget.props
*.nuget.targets

# SDK projects (new format)
[Bb]in/
[Oo]bj/

# Legacy project format
*.user
*.userosscache
*.sln.docstates
*.csproj.user
*.fsproj.user
*.vbproj.user

# Backup & temporary files
*~
*.bak
*.tmp
*.swp
*.swo
Thumbs.db
Thumbs.db:*
ehthumbs.db

